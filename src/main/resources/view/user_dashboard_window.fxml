<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.UserDashboardWindowController">
   <children>
      <Rectangle fill="#0e4c92" height="400.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" width="200.0" />
      <Label layoutX="18.0" layoutY="14.0" text="User Dashboard" textFill="WHITE">
         <font>
            <Font name="System Bold" size="22.0" />
         </font>
      </Label>
      <Button fx:id="btnAddProducts" layoutX="6.0" layoutY="53.0" mnemonicParsing="false" onAction="#btnAddProductsFormOnAction" style="-fx-background-color: #061E3A;" text="Add Products Form" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Button>
      <Button fx:id="btnViewProducts" layoutX="10.0" layoutY="100.0" mnemonicParsing="false" onAction="#btnViewProductsWindowOnAction" style="-fx-background-color: #061E3A;" text="Modify Prod Form" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Button>
      <AnchorPane fx:id="ancPaneLoadContainer" layoutX="200.0" prefHeight="400.0" prefWidth="601.0" />
      <Button fx:id="btnSupplierForm" layoutX="27.0" layoutY="147.0" mnemonicParsing="false" onAction="#btnSupplierFormOnAction" style="-fx-background-color: #061E3A;" text="Supplier Form" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Button>
      <Button fx:id="btnOrderForm" layoutX="39.0" layoutY="288.0" mnemonicParsing="false" onAction="#btnOrderFormOnAction" style="-fx-background-color: #061E3A;" text="Order Form" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Button>
      <Button fx:id="btnViewAllOrders" layoutX="13.0" layoutY="335.0" mnemonicParsing="false" onAction="#btnViewAllOrdersWindowOnAction" style="-fx-background-color: #061E3A;" text="Orders &amp; Returns" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Button>
      <Button fx:id="btnViewSupplierProducts" layoutX="6.0" layoutY="194.0" mnemonicParsing="false" onAction="#btnViewSupplierProductsOnAction" prefHeight="39.0" prefWidth="188.0" style="-fx-background-color: #061E3A;" text="View Supplier Prod" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Button>
      <Button fx:id="btnCustomerForm" layoutX="7.0" layoutY="241.0" mnemonicParsing="false" onAction="#btnViewCustomerFormOnAction" prefHeight="39.0" prefWidth="188.0" style="-fx-background-color: #061E3A;" text="Customer Form" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
